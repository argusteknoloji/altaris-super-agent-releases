{
  "realm": "altaris",
  "enabled": true,
  "displayName": "Altaris Platform",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 604800,
  "ssoSessionIdleTimeout": 604800,
  "ssoSessionMaxLifespan": 604800,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespan": 5184000,
  "oauth2DeviceCodeLifespan": 600,
  "oauth2DevicePollingInterval": 5,
  "attributes": {
    "frontendUrl": "http://localhost:8081"
  },
  "roles": {
    "realm": [
      {
        "name": "tenant_admin",
        "description": "Tenant administrator"
      },
      {
        "name": "tenant_member",
        "description": "Tenant member (default)"
      },
      {
        "name": "platform_admin",
        "description": "Cross-tenant Argus operator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "altaris-cli",
      "name": "Altaris CLI",
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true",
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "basic",
        "tenant",
        "roles"
      ],
      "optionalClientScopes": [
        "email",
        "profile"
      ],
      "redirectUris": [
        "http://localhost:*"
      ]
    },
    {
      "clientId": "altaris-web",
      "name": "Altaris Web Portal",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "rootUrl": "http://localhost:3000",
      "redirectUris": [
        "http://localhost:3000/api/auth/callback/keycloak"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000##http://localhost:3000/##http://localhost:3000/api/auth/callback/keycloak"
      },
      "defaultClientScopes": [
        "basic",
        "tenant",
        "roles"
      ],
      "optionalClientScopes": [
        "email",
        "profile"
      ],
      "protocolMappers": [
        {
          "name": "tid",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tid",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        }
      ]
    },
    {
      "clientId": "altaris-api",
      "name": "Altaris API",
      "bearerOnly": true,
      "publicClient": false,
      "secret": "dev-only-altaris-api-secret-replace-in-prod"
    },
    {
      "clientId": "altaris-admin-svc",
      "name": "Altaris Admin Service Account",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "dev-only-altaris-admin-svc-secret-replace-in-prod"
    }
  ],
  "clientScopes": [
    {
      "name": "tenant",
      "description": "Inject tenant_id into tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tid",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "subject",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "config": {
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "email_in_token",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "altaris-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "realm_roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "burak",
      "enabled": true,
      "email": "burak@argusteknoloji.com",
      "firstName": "Burak",
      "lastName": "Demirsoy",
      "emailVerified": true,
      "attributes": {
        "tenant_id": [
          "argus"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "altaris_dev",
          "temporary": false
        }
      ],
      "realmRoles": [
        "tenant_admin",
        "platform_admin"
      ]
    }
  ]
}