# Altaris Production env. Copy to .env.production and replace ALL placeholder
# secrets before bringing the stack up. Generate strong secrets:
#   openssl rand -base64 32
#
# DO NOT commit .env.production. .gitignore excludes it.

# ── Hostnames (must point to this host's public IP) ─────────────────────────
WEB_HOSTNAME=altaris.argusteknoloji.com
KC_HOSTNAME=auth.argusteknoloji.com
API_HOSTNAME=api.argusteknoloji.com
LETSENCRYPT_EMAIL=ops@argusteknoloji.com

# ── Postgres (Altaris app DB) ───────────────────────────────────────────────
POSTGRES_USER=altaris
POSTGRES_PASSWORD=replace-me-with-openssl-rand-base64-32
POSTGRES_DB=altaris

# ── Postgres (Keycloak DB) ──────────────────────────────────────────────────
KC_DB_USER=keycloak
KC_DB_PASSWORD=replace-me-with-openssl-rand-base64-32
KC_DB_NAME=keycloak

# ── Keycloak admin ──────────────────────────────────────────────────────────
KC_REALM=altaris
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=replace-me-with-openssl-rand-base64-32
KC_ADMIN_SVC_SECRET=replace-me-with-openssl-rand-base64-48

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=replace-me-with-openssl-rand-base64-32

# ── Web (NextAuth) ──────────────────────────────────────────────────────────
WEB_AUTH_SECRET=replace-me-with-openssl-rand-base64-32
WEB_KEYCLOAK_SECRET=

# ── Image tag ───────────────────────────────────────────────────────────────
ALTARIS_VERSION=v0.1.0-alpha.1

# ── Backup retention ────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=14
