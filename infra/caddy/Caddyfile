# Altaris Caddy reverse proxy — production
# Auto-TLS via Let's Encrypt; her host için cert otomatik provision edilir.
# Multi-domain: WEB_HOSTNAMES vb. boşlukla ayrılmış olabilir
# (örn. "altarisplatform.com altaris.run") — Caddy native space-separated host matching.

{
    email {$LETSENCRYPT_EMAIL}
    servers {
        protocols h1 h2 h3
    }
}

# ── Web portal (Next.js) ────────────────────────────────────────────────────
{$WEB_HOSTNAMES} {
    encode zstd gzip
    reverse_proxy web:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }
}

# ── Keycloak (SSO endpoint) ─────────────────────────────────────────────────
{$KC_HOSTNAMES} {
    encode zstd gzip
    reverse_proxy keycloak:8080 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }
}

# ── API (CLI / Desktop / external integrations için public) ─────────────────
{$API_HOSTNAMES} {
    encode zstd gzip
    reverse_proxy api:5000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        # WebSocket / SSE: /ws/pty, /ws/remote-control, executive-brain stream
        flush_interval -1
    }
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }
}
