# Altaris Caddy reverse proxy — production
# Auto-TLS via Let's Encrypt; her host için cert otomatik provision edilir.
#
# Domain stratejisi: altarisplatform.com canonical. altaris.run brand alias —
# her isteği altarisplatform.com'a 301 yönlendirir (NextAuth v5 multi-domain
# OAuth flow'unu desteklemiyor; tek canonical host gerek).

{
    email {$LETSENCRYPT_EMAIL}
    servers {
        protocols h1 h2 h3
    }
}

# ── altaris.run brand alias → altarisplatform.com (301 permanent) ───────────
altaris.run {
    redir https://altarisplatform.com{uri} permanent
}
api.altaris.run {
    redir https://api.altarisplatform.com{uri} permanent
}
auth.altaris.run {
    redir https://auth.altarisplatform.com{uri} permanent
}

# ── Web portal (Next.js) ────────────────────────────────────────────────────
altarisplatform.com {
    encode zstd gzip
    reverse_proxy web:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }

    # /_next/static/* dosyalari hash'li -> immutable cache (uzun)
    # Diger her sey (HTML, server-rendered page, /api/*) -> no-cache
    # ki deploy sonrasi tarayici eski JS bundle'i tutmasin.
    @nextStatic path /_next/static/*
    header @nextStatic Cache-Control "public, max-age=31536000, immutable"

    @notStatic not path /_next/static/*
    header @notStatic Cache-Control "no-cache, no-store, must-revalidate"
    header @notStatic Pragma        "no-cache"
    header @notStatic Expires       "0"

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        -Server
    }
}

# ── Keycloak (SSO endpoint) ─────────────────────────────────────────────────
auth.altarisplatform.com {
    encode zstd gzip
    reverse_proxy keycloak:8080 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
    }
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }
}

# ── API (CLI / Desktop / external integrations için public) ─────────────────
api.altarisplatform.com {
    encode zstd gzip
    reverse_proxy api:5000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        # WebSocket / SSE: /ws/pty, /ws/remote-control, executive-brain stream
        flush_interval -1
    }
    # API'nin tamamı tenant-scoped + auth-bound → asla cache'lenmesin
    # (browser, ara proxy, CDN). WebSocket upgrade'lere zaten uygulanmaz.
    header {
        Cache-Control             "no-store, no-cache, must-revalidate, max-age=0"
        Pragma                    "no-cache"
        Expires                   "0"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }
}
