{
  "name": "altaris",
  "displayName": "Altaris",
  "description": "Altaris CLI ↔ VS Code köprüsü. Editör seçimini paylaş, diff'leri editor'da onayla, diagnostics'i CLI'a aktar.",
  "version": "0.1.0",
  "publisher": "argus",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Other"],
  "keywords": ["altaris", "argus", "ai", "agent", "cli"],
  "main": "./dist/extension.js",
  "icon": "icon.png",
  "activationEvents": [
    "onStartupFinished",
    "onNotebook:jupyter-notebook"
  ],
  "contributes": {
    "commands": [
      { "command": "altaris.showStatus",     "title": "Altaris: Bağlantı durumunu göster" },
      { "command": "altaris.restart",        "title": "Altaris: Köprüyü yeniden başlat" },
      { "command": "altaris.restartBridge",  "title": "Altaris: Köprüyü yeniden başlat (alias)" },
      { "command": "altaris.showOutput",     "title": "Altaris: Output panelini aç" },
      {
        "command": "altaris.openTerminal",
        "title": "Altaris: Yeni terminal aç",
        "icon": {
          "light": "./media/altaris.svg",
          "dark": "./media/altaris.svg"
        }
      },
      { "command": "altaris.statusBar.menu", "title": "Altaris: Status menü" },
      { "command": "altaris.switchModel",    "title": "Altaris: Model değiştir" },
      { "command": "altaris.inlineEdit",     "title": "Altaris: Inline edit" },
      { "command": "altaris.fixWithAi",      "title": "Altaris: Fix with AI" },
      { "command": "altaris.lens.explain",   "title": "Altaris: Explain" },
      { "command": "altaris.lens.test",      "title": "Altaris: Generate tests" },
      { "command": "altaris.lens.refactor",  "title": "Altaris: Refactor" },
      { "command": "altaris.insertWorkspaceFile", "title": "Altaris: Workspace dosyası ekle (@)" },
      { "command": "altaris.diff.accept",    "title": "Altaris: Diff'i kabul et" },
      { "command": "altaris.diff.reject",    "title": "Altaris: Diff'i reddet" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "altaris-sidebar",
          "title": "Altaris",
          "icon": "./media/altaris.svg"
        }
      ]
    },
    "views": {
      "altaris-sidebar": [
        {
          "id": "altaris.welcome",
          "name": "Altaris",
          "icon": "./media/altaris.svg",
          "contextualTitle": "Altaris"
        }
      ]
    },
    "menus": {
      "terminal/title/context": [
        {
          "command": "altaris.openTerminal",
          "group": "navigation@1"
        }
      ],
      "view/title": [
        {
          "command": "altaris.openTerminal",
          "when": "view == terminal",
          "group": "navigation@1"
        }
      ],
      "editor/title": [
        {
          "command": "altaris.openTerminal",
          "group": "navigation@99"
        }
      ]
    },
    "keybindings": [
      {
        "command": "altaris.inlineEdit",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      },
      {
        "command": "altaris.insertWorkspaceFile",
        "key": "shift+ctrl+2",
        "mac": "shift+cmd+2"
      }
    ],
    "terminal": {
      "profiles": [
        {
          "title": "Altaris",
          "id": "altaris.terminal-profile",
          "icon": "./media/altaris.svg"
        }
      ]
    },
    "configuration": {
      "title": "Altaris",
      "properties": {
        "altaris.lockfileDir": {
          "type": "string",
          "default": "",
          "description": "Lockfile dizini override (varsayılan: ~/.altaris/ide). Boş bırak."
        },
        "altaris.cli.models": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Status bar 'Switch model' quick pick'inde gösterilecek model listesi."
        },
        "altaris.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Function/method üstüne 'Explain · Test · Refactor' code lens göster."
        },
        "altaris.fileWatcher.includeUnsaved": {
          "type": "boolean",
          "default": false,
          "description": "Kaydedilmemiş değişiklikleri de CLI'a push et (debounced 500ms)."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "prebuild": "bun run scripts/bump.ts || true",
    "typecheck": "tsc -p . --noEmit",
    "watch": "node esbuild.js --watch",
    "package": "npm run build && vsce package --no-dependencies -o altaris.vsix && node -e \"const fs=require('fs'); const v=require('./package.json').version; fs.copyFileSync('altaris.vsix', 'altaris-'+v+'.vsix')\"",
    "publish": "npm run build && vsce publish --no-dependencies",
    "test": "bun test test/"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/argusteknoloji/altaris"
  },
  "license": "PROPRIETARY"
}
