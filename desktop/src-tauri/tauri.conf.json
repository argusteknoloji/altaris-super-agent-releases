{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Altaris",
  "version": "0.1.0-alpha.1",
  "identifier": "com.argusteknoloji.altaris.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Altaris",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:5000 ws://localhost:5000 http://localhost:8081 https://api.anthropic.com https://api.openai.com http://localhost:11434 http://localhost:1234; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Argus Teknoloji",
    "copyright": "© 2026 Argus Teknoloji",
    "category": "DeveloperTool",
    "shortDescription": "Altaris — Enterprise AI Desktop",
    "longDescription": "Argus Teknoloji enterprise agentic AI desktop application. Chat, code editor, integrated terminal. Multi-tenant. On-prem ready.",
    "macOS": {
      "minimumSystemVersion": "13.0",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "exceptionDomain": "localhost",
      "signingIdentity": null,
      "providerShortName": null
    },
    "windows": {
      "nsis": { "languages": ["English", "Turkish"] }
    }
  },
  "plugins": {
    "shell": { "open": true },
    "store": {},
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/argusteknoloji/altaris-super-agent-releases/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxMkQ1ODcyOEFERTlCNDYKUldSR205NktjbGd0OGQ1YnV2Q0hwSCtpektlRDd2VHl6TXhGa3VtaG81VzY5a2RUMXVpK09DaEUK"
    }
  }
}
